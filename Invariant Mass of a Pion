#include <iostream>
#include <cmath>

// ROOT Header Files
#include "TFile.h"
#include "TTree.h"
#include "TH1F.h"
#include "TCanvas.h"
#include "TApplication.h"

// Pythia Header File (Needed to interpret the event objects)
#include "Pythia8/Pythia.h"

using namespace Pythia8;

int main(int argc, char* argv[]) {

  // Create the ROOT application environment
  TApplication theApp("hist", &argc, argv);

  TFile* inFile = TFile::Open("pytree.root", "READ");
  if (!inFile || inFile->IsZombie()) {
    std::cerr << "Error: Could not open pytree.root!" << std::endl;
    return 1;
  }

  // 2. Extract the Data Tree
  TTree* tree = (TTree*)inFile->Get("GAM");
  TTree* tree2 = (TTree*)inFile->Get("m");

  // 3. Set up a placeholder variable to read data back out of the tree
  std::vector<double>* e = nullptr;
  tree->SetBranchAddress("e", &e);
  std::vector<double>* px = nullptr;
  tree->SetBranchAddress("px", &px);
  std::vector<double>* py = nullptr;
  tree->SetBranchAddress("py", &py);
  std::vector<double>* pz = nullptr;
  tree->SetBranchAddress("pz", &pz);
  std::vector<double>* m = nullptr;
  tree->SetBranchAddress("m", &m);

  // 4. Initialize the Canvas and the E Histogram
  TCanvas* c1 = new TCanvas("c1", "Pythia Analysis", 1200, 600);
  TH1F* mHist = new TH1F("mHist", "Invariant Mass;M [GeV];Entries", 100, 0.0, 1.0);

  // 5. Loop over all simulated events inside the ROOT tree
  Long64_t nEvents = tree->GetEntries();
  std::vector<double> *e_vector = nullptr;
  std::vector<double> *px_vector = nullptr;
  std::vector<double> *py_vector = nullptr;
  std::vector<double> *pz_vector = nullptr;
  
 tree->SetBranchAddress("e", &e_vector);
 tree->SetBranchAddress("px", &px_vector);
 tree->SetBranchAddress("py", &py_vector);
 tree->SetBranchAddress("pz", &pz_vector);

  std::cout << "\nAnalysis complete. Close the graphical window to quit.\n";

  size_t nPhotons = e_vector->size();
  for (Long64_t i = 0; i < nEvents; ++i) {
    tree->GetEntry(i);
    size_t nPhotons = e_vector->size();
    for (size_t j = 0; j < nPhotons; ++j) {
      for (size_t k = j + 1; k < nPhotons; ++k) {
        double e_sum = (*e_vector)[j] + (*e_vector)[k];
                double px_sum = (*px_vector)[j] + (*px_vector)[k];
                double py_sum = (*py_vector)[j] + (*py_vector)[k];
                double pz_sum = (*pz_vector)[j] + (*pz_vector)[k];
                // M^2 = E^2 - |p|^2
                double M2 = (e_sum * e_sum) - (px_sum * px_sum + py_sum * py_sum + pz_sum * pz_sum);
                
        mHist->Fill(sqrt(M2)); // Fill the histogram with the invariant mass
      }
    }
  }

  c1->cd(2);
  mHist->Draw();
  c1->SaveAs("/Users/lucashill/Downloads/Python/Klay_Lab_Work/PionMass.png");


  double accepted_mass = 0.135;
  double selected_mass = mHist->GetBinCenter(mHist->GetMaximumBin());
  std::cout << "Selected mass: " << selected_mass << std::endl;
  double deviation = std::abs(selected_mass - accepted_mass);
  std::cout << "Deviation from accepted mass: " << deviation << std::endl;
  double percent_deviation = (deviation / accepted_mass) * 100.0;
  std::cout << "Percent deviation: " << percent_deviation << "%" << std::endl;

  theApp.Run();
  // Clean up variables after the app window closes
  inFile->Close();
  delete inFile;
  
  return 0;
}

