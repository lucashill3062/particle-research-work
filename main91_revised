// This is a simple test program
// It studies the charged multiplicity distribution at the LHC.
// Modified by Rene Brun, Axel Naumann and Bernhard Meirose
// to use ROOT for histogramming.

// Stdlib header file for input and output.
#include <iostream>

// Header file to access Pythia 8 program elements.
#include "Pythia8/Pythia.h"

// ROOT, for histogramming.
#include "TH1.h"

// ROOT, for interactive graphics.
#include "TVirtualPad.h"
#include "TApplication.h"

// ROOT, for saving file.
#include "TFile.h"

#include "TCanvas.h"
#include "TH1F.h"

using namespace Pythia8;

int main(int argc, char* argv[]) {

  // Create the ROOT application environment.
  TApplication theApp("hist", &argc, argv);

  // Create Pythia instance and set it up to generate hard QCD processes
  // above pTHat = 20 GeV for pp collisions at 14 TeV.
  Pythia pythia;
  pythia.readString("HardQCD:all = on");
  pythia.readString("PhaseSpace:pTHatMin = 20.");
  pythia.readString("Beams:eCM = 14000.");
  pythia.init();

  // 1. Create a ROOT File to save the output
TFile* outFile = new TFile("pythia_output.root", "RECREATE");

// 2. Initialize the canvas for drawing
TCanvas* c1 = new TCanvas("c1", "Pythia Plots", 800, 600);

// 3. Initialize the Multiplicity Histogram
// Arguments: ("Name", "Title;X-Axis;Y-Axis", Number of Bins, X-Low, X-High)
TH1F* multHist = new TH1F("multHist", "Charged Particle Multiplicity;N_{charged};Events",100, -0.5, 799.5);

// 4. Initialize the Transverse Momentum Histogram
TH1F* ptHist = new TH1F("ptHist", "Charged Particle p_{T};p_{T} [GeV/c];Entries", 100, -1, 20.0);


  // Begin event loop. Generate event; skip if generation aborted.
  for (int iEvent = 0; iEvent < 100; ++iEvent) {
    if (!pythia.next()) continue;

    // Find number of all final charged particles.
    int nCharged = 0;
    for (int i = 0; i < pythia.event.size(); ++i) {
      if (pythia.event[i].isFinal() && pythia.event[i].isCharged()) {
        ++nCharged;
        
        // Calculate and fill pT for each individual charged particle
        double px = pythia.event[i].px();
        double py = pythia.event[i].py();
        double pT = sqrt(px * px + py * py); // Or use pythia.event[i].pT();
        
        ptHist->Fill(pT); 
      }
    }
    multHist->Fill(nCharged);
  }

  // Statistics on event generation.
  pythia.stat();

  c1->Divide(1, 2);
  c1->cd(1); multHist->Draw();
  c1->cd(2); ptHist->Draw();

  // Show histogram. Possibility to close it.
  std::cout << "\nClose the window to quit.\n";
  theApp.Run();

  // Save histograms to file and close file.
  multHist->Write();
  ptHist->Write();
  delete outFile;
  delete outFile;

  new TApplication("app", 0, 0); 
  gApplication->Run();
  
  // Done.
  return 0;
}
