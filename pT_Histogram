#include <iostream>
#include <cmath>

// ROOT Header Files
#include "TFile.h"
#include "TTree.h"
#include "TH1F.h"
#include "TCanvas.h"
#include "TApplication.h"

// Pythia Header File (Needed to interpret the event objects)
#include "Pythia8/Pythia.h"

using namespace Pythia8;

int main(int argc, char* argv[]) {

  // Create the ROOT application environment
  TApplication theApp("hist", &argc, argv);

  TFile* inFile = TFile::Open("pytree.root", "READ");
  if (!inFile || inFile->IsZombie()) {
    std::cerr << "Error: Could not open pytree.root!" << std::endl;
    return 1;
  }

  // 2. Extract the Data Tree
  TTree* tree = (TTree*)inFile->Get("T");

  // 3. Set up a placeholder variable to read data back out of the tree
  std::vector<double>* pT = nullptr;
  tree->SetBranchAddress("pT", &pT);

  // 4. Initialize the Canvas and the pT Histogram
  TCanvas* c1 = new TCanvas("c1", "Pythia Analysis", 800, 600);
  TH1F* ptHist = new TH1F("ptHist", "Final State, Charged p_{T};p_{T} [GeV/c];Entries", 100, 0.0, 20);

  // 5. Loop over all simulated events inside the ROOT tree
  Long64_t nEvents = tree->GetEntries();
  std::vector<double> *pT_vector = nullptr;

  
tree->SetBranchAddress("pT", &pT_vector);

for (Long64_t i = 0; i < tree->GetEntries(); ++i) {
    tree->GetEntry(i);
    for (double pT_val : *pT_vector) {
        ptHist->Fill(pT_val); // Draw directly into your plot!
    }
}

  // 6. Draw the plot
  c1->SetLogy(); // Set Y axis to a log scale so high pT tail is visible
  ptHist->Draw();
  c1->SaveAs("/Users/lucashill/Downloads/Python/Klay_Lab_Work/pt_distribution.png");

  std::cout << "\nAnalysis complete. Close the graphical window to quit.\n";
  theApp.Run();

  // Clean up opened file pointers safely
  inFile->Close();
  delete inFile;
  
  return 0;
}
